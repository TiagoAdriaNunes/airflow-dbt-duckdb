{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Docker container resources via OpenTelemetry docker_stats receiver — CPU, memory, network, disk I/O",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_memory_usage_total_bytes",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "Memory Usage per Container",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_cpu_utilization_ratio",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "CPU Utilization per Container",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "unit": "bytes",
          "custom": { "align": "left", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Memory" },
            "properties": [
              { "id": "custom.displayMode", "value": "lcd-gauge" },
              { "id": "max", "value": 2147483648 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Memory" }] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_memory_usage_total_bytes",
          "instant": true,
          "legendFormat": "{{container_name}}",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Current Memory — Ranked",
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["last"] } },
        { "id": "organize", "options": { "renameByName": { "Field": "Container", "Last": "Memory" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(container_network_io_usage_rx_bytes_total[2m])",
          "legendFormat": "{{container_name}} rx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(container_network_io_usage_tx_bytes_total[2m])",
          "legendFormat": "{{container_name}} tx",
          "refId": "B"
        }
      ],
      "title": "Network I/O per Container",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(container_blockio_io_service_bytes_recursive_total{operation=\"read\"}[2m])",
          "legendFormat": "{{container_name}} read",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(container_blockio_io_service_bytes_recursive_total{operation=\"write\"}[2m])",
          "legendFormat": "{{container_name}} write",
          "refId": "B"
        }
      ],
      "title": "Disk I/O per Container (read / write throughput)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 27 },
      "id": 6,
      "options": { "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_memory_percent_ratio",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "title": "Memory % of Host Limit per Container",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "custom": { "align": "left", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "custom.displayMode", "value": "lcd-gauge" },
              { "id": "max", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 27 },
      "id": 7,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "CPU %" }] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_cpu_utilization_ratio",
          "instant": true,
          "legendFormat": "{{container_name}}",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Current CPU — Ranked",
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["last"] } },
        { "id": "organize", "options": { "renameByName": { "Field": "Container", "Last": "CPU %" } } }
      ],
      "type": "table"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["docker", "opentelemetry", "resources"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Container Resources",
  "uid": "container-resources",
  "version": 4
}
